# =====================================================
# INMOLAWYER - Variables de Entorno
# Copiar este archivo como .env y completar los valores
# =====================================================

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=inmolawyer
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_contraseña

# n8n Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Anthropic API (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Webhook URLs (se generan automáticamente al activar el workflow)
# Estos son los endpoints que usará la webapp
WEBHOOK_ANALIZAR_CONTRATO=http://localhost:5678/webhook/analizar-contrato
WEBHOOK_CONSULTA_CONTRATO=http://localhost:5678/webhook/consulta-contrato
WEBHOOK_CALCULAR_INCREMENTO=http://localhost:5678/webhook/calcular-incremento

# Configuración del Agente IA (actualizado)
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS_ANALISIS=4096
CLAUDE_MAX_TOKENS_CHAT=2048
CLAUDE_TEMPERATURE=0.3

# Configuración de Almacenamiento (opcional)
STORAGE_PATH=/path/to/contratos
MAX_FILE_SIZE_MB=10
